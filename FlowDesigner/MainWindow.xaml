<Window x:Class="FlowDesigner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FlowDesigner"
        mc:Ignorable="d"
        Title="FlowDesigner (MVP)"
        Height="840"
        Width="1300"
        MinHeight="680"
        MinWidth="1100">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Content="新建" Width="80" Margin="0,0,6,0" Click="NewFlow_Click" />
                <Button Content="加载" Width="80" Margin="0,0,6,0" Click="LoadFlow_Click" />
                <Button Content="保存" Width="80" Margin="0,0,6,0" Click="SaveFlow_Click" />
                <Button Content="运行" Width="80" Margin="0,0,6,0" Click="RunFlow_Click" />
                <Button Content="同步JSON" Width="100" Click="SyncJson_Click" />
            </StackPanel>
            <TextBlock Name="StatusText"
                       DockPanel.Dock="Right"
                       VerticalAlignment="Center"
                       Text="就绪"
                       FontWeight="SemiBold" />
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="步骤列表（顺序）" Grid.Column="0" Margin="0,0,10,0">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="6">
                        <Button Content="添加步骤" Width="90" Margin="0,0,6,0" Click="AddStep_Click" />
                        <Button Content="删除步骤" Width="90" Margin="0,0,6,0" Click="DeleteStep_Click" />
                        <Button Content="上移" Width="80" Margin="0,0,6,0" Click="MoveUp_Click" />
                        <Button Content="下移" Width="80" Click="MoveDown_Click" />
                    </StackPanel>
                    <DataGrid Name="StepsGrid"
                              Margin="6"
                              ItemsSource="{Binding Steps}"
                              SelectedItem="{Binding SelectedStep, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id" Binding="{Binding Id, UpdateSourceTrigger=PropertyChanged}" Width="1.2*" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="1.4*" />
                            <DataGridTextColumn Header="Type" Binding="{Binding Type, UpdateSourceTrigger=PropertyChanged}" Width="1*" />
                            <DataGridTextColumn Header="Action" Binding="{Binding Action, UpdateSourceTrigger=PropertyChanged}" Width="1.4*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </GroupBox>

            <GroupBox Header="步骤属性编辑" Grid.Column="1">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="Id" />
                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,12,8" Text="{Binding SelectedStep.Id, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Margin="0,0,8,8" VerticalAlignment="Center" Text="Name" />
                    <TextBox Grid.Row="0" Grid.Column="3" Margin="0,0,0,8" Text="{Binding SelectedStep.Name, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="Type" />
                    <ComboBox Grid.Row="1"
                              Grid.Column="1"
                              Margin="0,0,12,8"
                              IsEditable="True"
                              Text="{Binding SelectedStep.Type, UpdateSourceTrigger=PropertyChanged}">
                        <ComboBoxItem Content="CallMethod" />
                        <ComboBoxItem Content="If" />
                        <ComboBoxItem Content="ForEach" />
                        <ComboBoxItem Content="TryCatch" />
                    </ComboBox>

                    <TextBlock Grid.Row="1" Grid.Column="2" Margin="0,0,8,8" VerticalAlignment="Center" Text="Action" />
                    <ComboBox Grid.Row="1"
                              Grid.Column="3"
                              Margin="0,0,0,8"
                              IsEditable="True"
                              Text="{Binding SelectedStep.Action, UpdateSourceTrigger=PropertyChanged}">
                        <ComboBoxItem Content="SetVariable" />
                        <ComboBoxItem Content="Delay" />
                        <ComboBoxItem Content="AssertEquals" />
                        <ComboBoxItem Content="ReadFile" />
                        <ComboBoxItem Content="HttpRequest" />
                        <ComboBoxItem Content="RunScript" />
                    </ComboBox>

                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="TimeoutMs" />
                    <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,12,8" Text="{Binding SelectedStep.TimeoutMs, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Grid.Row="2" Grid.Column="2" Margin="0,0,8,8" VerticalAlignment="Center" Text="Retry" />
                    <TextBox Grid.Row="2" Grid.Column="3" Margin="0,0,0,8" Text="{Binding SelectedStep.Retry, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="OnError" />
                    <ComboBox Grid.Row="3"
                              Grid.Column="1"
                              Margin="0,0,12,8"
                              IsEditable="True"
                              Text="{Binding SelectedStep.OnError, UpdateSourceTrigger=PropertyChanged}">
                        <ComboBoxItem Content="Stop" />
                        <ComboBoxItem Content="Continue" />
                    </ComboBox>

                    <TextBlock Grid.Row="4" Grid.ColumnSpan="4" Margin="0,8,0,4" FontWeight="SemiBold" Text="Inputs（JSON对象）" />
                    <TextBox Grid.Row="5"
                             Grid.ColumnSpan="4"
                             Text="{Binding SelectedStep.InputsJson, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             Height="120"
                             FontFamily="Consolas"
                             FontSize="13" />

                    <TextBlock Grid.Row="6" Grid.ColumnSpan="4" Margin="0,8,0,4" FontWeight="SemiBold" Text="Outputs（JSON对象: {outputName: variableName}）" />
                    <TextBox Grid.Row="7"
                             Grid.ColumnSpan="4"
                             Text="{Binding SelectedStep.OutputsJson, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             FontSize="13" />
                </Grid>
            </GroupBox>
        </Grid>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="流程JSON（高级模式，可直接编辑）" Margin="0,0,10,0">
                <TextBox Name="FlowJsonTextBox"
                         Margin="8"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         FontFamily="Consolas"
                         FontSize="13" />
            </GroupBox>

            <GroupBox Grid.Column="1" Header="运行日志">
                <TextBox Name="RunLogTextBox"
                         Margin="8"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         FontSize="13" />
            </GroupBox>
        </Grid>
    </Grid>
</Window>
